# ============================================================
# MATH 2033+3033 Note — Git Ignore Rules
# ============================================================

# --- LaTeX 编译中间文件 ---
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex*
*.blg
*.bbl
*.run.xml
*.bcf
*.idx
*.ilg
*.ind
*.thm
*.ptc
*.nav
*.snm
*.vrb
*.xdv

# --- PDF 输出（通过 GitHub Release 手动发布） ---
*.pdf

# --- 保留 Images 目录中的资源 PDF ---
!**/Images/*.pdf

# --- 临时文件 ---
*.tmp
*~
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Python 虚拟环境 ---
.venv/

# --- 压缩包 ---
*.zip

# --- 工作区文件（不纳入版本控制） ---
*.code-workspace
.workbuddy/

# ============================================================
# 白名单：保留以下源文件类型（优先级高于上述规则）
# ============================================================
!*.tex
!*.bib
!*.sty
!*.cls
!*.bst
!*.ist
!*.py
